API_HOST=127.0.0.1
API_PORT=8001
API_DEBUG=true
API_AUTH_ENABLED=false
READIRECT_AI_API_TOKEN=
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

ASR_PROVIDER=wav2vec2_only
ASR_ARCHITECTURE=wav2vec2_only
ASR_MODEL_NAME=epsilon
ASR_MODEL_PATH=models/asr/epsilon
ASR_MODEL_SIZE=models/asr/epsilon
WAV2VEC2_ASR_MODEL_PATH=models/asr/epsilon
WAV2VEC2_PHONEME_MODEL_PATH=models/wav2vec2-phoneme
WAV2VEC2_BASE_ASR_MODEL_PATH=models/wav2vec2-readirect-asr
ALLOW_WAV2VEC2_BASE_FALLBACK=false
TRANSFORMERS_OFFLINE=1
GIGASPEECH_CACHE_DIR=external_datasets/hf_cache
WAV2VEC2_ALPHA_BASE_MODEL_PATH=models/wav2vec2-base-960h
ALPHA_CHECKPOINT_PATH=models/asr/alpha
BETA_CHECKPOINT_PATH=models/asr/beta
GIGASPEECH_S_PATH=external_datasets/gigaspeech_s_parquet/parquet-data/s
GIGASPEECH_S_MAX_ROWS=0
READIRECT_LETTERS_REPEAT_FACTOR=1
SPEECHOCEAN_TRAIN_MANIFEST=external_datasets/manifests/speechocean_train.jsonl
SPEECHOCEAN_VALID_MANIFEST=external_datasets/manifests/speechocean_valid.jsonl
SPEECHOCEAN_TEST_MANIFEST=external_datasets/manifests/speechocean_test.jsonl
READIRECT_LETTERS_ROOT=external_datasets/readirect_letters
READIRECT_LETTERS_TRAIN_MANIFEST=external_datasets/readirect_letters/manifests/readirect_letters_train.jsonl
READIRECT_LETTERS_VALID_MANIFEST=external_datasets/readirect_letters/manifests/readirect_letters_valid.jsonl
READIRECT_LETTERS_TEST_MANIFEST=external_datasets/readirect_letters/manifests/readirect_letters_test.jsonl
FFMPEG_BIN_DIR=
ASR_DEVICE=cuda
ASR_DECODE_MODE=beam_lm
ASR_BEAM_WIDTH=100
ASR_LM_PATH=external_datasets/language_models/3-gram.pruned.1e-7.arpa
ASR_ALPHA=0.5
ASR_BETA=1.0
ASR_HOTWORDS=
ASR_HOTWORD_WEIGHT=5.0
ASR_ALLOW_NO_LM_FALLBACK=false
ASR_LANGUAGE=en
ASR_BATCH_LIMIT=50
ASR_TIMEOUT_SECONDS=60
AUDIO_MIN_DURATION_SECONDS=1.0
AUDIO_MAX_DURATION_SECONDS=30.0
AUDIO_LOW_VOLUME_DBFS=-35.0
AUDIO_SILENCE_DBFS=-40.0
AUDIO_MOSTLY_SILENT_RATIO=0.85
AUDIO_CLIPPING_THRESHOLD=0.98
AUDIO_CLIPPED_RATIO_THRESHOLD=0.01
AUDIO_MIN_SPEECH_RATIO=0.15
AUDIO_LONG_PAUSE_SECONDS=1.0
AUDIO_VERY_LONG_PAUSE_SECONDS=2.0
AUDIO_ENABLE_QUALITY_GATE=true
AUDIO_RETRY_ON_BAD_QUALITY=true
PHONETIC_SINGLE_LETTER_THRESHOLD=0.85
PHONETIC_LATTICE_THRESHOLD=0.85
PHONETIC_KNOWN_CONFUSION_THRESHOLD=0.82
PHONETIC_ACCEPT_THRESHOLD=0.88
PHONETIC_STRICT_WORD_THRESHOLD=0.90
CRITICAL_PHONEME_REQUIRED=true
REINFORCEMENT_CORRECTIONS_ENABLED=true
REINFORCEMENT_CORRECTIONS_DIR=reinforcement-learning
LETTER_REINFORCEMENT_FILE=letter-reinforcement.csv
CONTENT_BANK_PATH=content_bank
CMUDICT_DIR=external_datasets/cmudict
DATA_MANIFEST_PATH=data/manifests/dataset_manifest.csv
CONTENT_INDEX_PATH=data/manifests/content_index.csv
ENRICHED_CONTENT_INDEX_PATH=content_bank_enriched/enriched_content_index.csv
AUDIO_BASE_PATH=data/raw
