API_HOST=127.0.0.1
API_PORT=8001
API_DEBUG=true
API_AUTH_ENABLED=false
READIRECT_AI_API_TOKEN=
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

ASR_PROVIDER=wav2vec2_only
ASR_ARCHITECTURE=wav2vec2_only
ASR_MODEL_SIZE=models/wav2vec2-readirect-asr-letters-v2
WAV2VEC2_ASR_MODEL_PATH=models/wav2vec2-readirect-asr-letters-v2
WAV2VEC2_PHONEME_MODEL_PATH=models/wav2vec2-phoneme
WAV2VEC2_BASE_ASR_MODEL_PATH=models/wav2vec2-readirect-asr
ALLOW_WAV2VEC2_BASE_FALLBACK=false
TRANSFORMERS_OFFLINE=1
ASR_DEVICE=cpu
ASR_LANGUAGE=en
ASR_BATCH_LIMIT=50
ASR_TIMEOUT_SECONDS=60
AUDIO_MIN_DURATION_SECONDS=1.0
AUDIO_MAX_DURATION_SECONDS=30.0
AUDIO_LOW_VOLUME_DBFS=-35.0
AUDIO_SILENCE_DBFS=-40.0
AUDIO_MOSTLY_SILENT_RATIO=0.85
AUDIO_CLIPPING_THRESHOLD=0.98
AUDIO_CLIPPED_RATIO_THRESHOLD=0.01
AUDIO_MIN_SPEECH_RATIO=0.15
AUDIO_LONG_PAUSE_SECONDS=1.0
AUDIO_VERY_LONG_PAUSE_SECONDS=2.0
AUDIO_ENABLE_QUALITY_GATE=true
AUDIO_RETRY_ON_BAD_QUALITY=true
PHONETIC_SINGLE_LETTER_THRESHOLD=0.85
PHONETIC_LATTICE_THRESHOLD=0.85
PHONETIC_KNOWN_CONFUSION_THRESHOLD=0.82
PHONETIC_ACCEPT_THRESHOLD=0.88
PHONETIC_STRICT_WORD_THRESHOLD=0.90
CRITICAL_PHONEME_REQUIRED=true
REINFORCEMENT_CORRECTIONS_ENABLED=true
REINFORCEMENT_CORRECTIONS_DIR=reinforcement-learning
LETTER_REINFORCEMENT_FILE=letter-reinforcement.csv
CONTENT_BANK_PATH=content_bank
CMUDICT_DIR=external_datasets/cmudict
DATA_MANIFEST_PATH=data/manifests/dataset_manifest.csv
CONTENT_INDEX_PATH=data/manifests/content_index.csv
ENRICHED_CONTENT_INDEX_PATH=content_bank_enriched/enriched_content_index.csv
AUDIO_BASE_PATH=data/raw
SPEECHOCEAN762_ARCHIVE_PATH=external_datasets/speechocean762/raw/speechocean762.tar.gz
SPEECHOCEAN762_DATASET_DIR=external_datasets/speechocean762/extracted
SPEECHOCEAN762_MANIFEST_PATH=data/manifests/speechocean762_manifest.csv
ANALYSIS_CONFIG_PATH=configs/analysis_config.yaml
ADAPTIVE_CONFIG_PATH=configs/adaptive_config.yaml
LOG_LEVEL=info
